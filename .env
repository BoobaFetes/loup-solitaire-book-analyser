ENV="dev"
ROOT_DIR="."
API_TIMEOUT=1.0
API_PARALLEL_CALLS=10
CONNECTION_STRING="data/"
LOG_FILE="logs/app.log"
LOG_LEVEL="INFO"
HEADLESS="true"
BROWSER_VIEWPORT_WIDTH="1920"
BROWSER_VIEWPORT_HEIGHT="1080"
BROWSER_LOCALE="fr-FR"
BROWSER_TIMEZONE="Europe/Paris"
BROWSER_ACCEPT_LANGUAGE="fr-FR,fr;q=0.9,en;q=0.8"
AMAZON_REQUEST_DELAY_SECONDS="1.0"

# NOTE des paramètres :
# HEADLESS ="false" 
# 1. volontairement à false car pour le moment playwright semble bloqué par amazon.fr en ne renvoyant pas les pages comme attendu
# 2. l'image kube sera aussi configurée pour ne pas être headless, afin de prévenir d'erreur rencontrées lors du developpement et de faciliter le debug