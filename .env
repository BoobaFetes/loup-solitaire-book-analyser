ENV="dev"
ROOT_DIR="."
API_TIMEOUT=1.0
API_PARALLEL_CALLS=10
CONNECTION_STRING="data/"
LOG_FILE="logs/app.log"
LOG_LEVEL="INFO"
HEADLESS="true"
BROWSER_VIEWPORT_WIDTH="1920"
BROWSER_VIEWPORT_HEIGHT="1080"
BROWSER_LOCALE="fr-FR"
BROWSER_TIMEZONE="Europe/Paris"
BROWSER_ACCEPT_LANGUAGE="fr-FR,fr;q=0.9,en;q=0.8"
AMAZON_REQUEST_DELAY_SECONDS="1.0"

# NOTE des paramètres :
# HEADLESS ="true" ou "false" (string) pour indiquer si le navigateur doit être lancé en mode headless ou non.
# 1. volontairement à false pour le developpement
# 2. l'image kube (en production) sera configurée pour être headless (donc à true), un job est prévu afin de vérifier systématiquement que le comportement en prod soit bel et bien celui attendu