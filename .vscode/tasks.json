{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Installer les dépendances",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}/requirements.txt"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
