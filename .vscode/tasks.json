{
  // Fichier tasks.json pour VS Code
  "version": "2.0.0",
  "tasks": [
    {
      "label": "check typings",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/pyright.exe",
      "args": ["${workspaceFolder}/src"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/pyright"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/pyright"
      },
      "presentation": {
        "reveal": "always",
        "clear": true
      },
      "problemMatcher": {
        "owner": "pyright",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+) - (error|warning|information): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    }
  ]
}
