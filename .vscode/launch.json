{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "launch find_books.py",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "program": "${workspaceFolder}/src/find_books.py",
      "console": "integratedTerminal",
      "preLaunchTask": "check typings",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "launch find_prices.py",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "program": "${workspaceFolder}/src/find_prices.py",
      "console": "integratedTerminal",
      "preLaunchTask": "check typings",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug PowerShell",
      "type": "PowerShell",
      "request": "launch",
      "script": "${file}",
      "cwd": "${fileDirname}"
    }
  ]
}
